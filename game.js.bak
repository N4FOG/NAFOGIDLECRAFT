        let gameState = {
            gold: 1000,
            bankSlots: 4,
            lastSave: Date.now(),
            currentPage: 'woodcutting',
            currentShopTab: 'mercado',
            currentAlchemyTab: 'craft',
            notificationStyle: 'default',
            customThemeColors: {
